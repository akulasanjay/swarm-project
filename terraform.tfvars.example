########################################
# Example terraform.tfvars
# Copy to terraform.tfvars and fill in values
########################################

aws_region   = "us-east-1"
project_name = "docker-swarm"
environment  = "prod"

vpc_cidr     = "10.0.0.0/16"
az_count     = 2
allowed_cidr = ["YOUR_IP/32"]   # Restrict SSH to your IP (leave [] to use SSM Session Manager only)

key_name              = "your-ec2-keypair"
manager_instance_type = "t3.medium"
worker_instance_type  = "t3.large"
manager_count         = 3
min_workers           = 2
max_workers           = 10
desired_workers       = 3
docker_version        = ""       # Leave empty for latest Docker CE

health_check_path = "/"
certificate_arn   = ""           # ACM cert ARN for HTTPS
hosted_zone_id    = ""           # Route 53 zone ID
domain_name       = ""           # e.g. swarm.example.com
